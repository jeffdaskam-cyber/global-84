rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    // A cohort member is a signed-in user with a *verified* email in the
    // allowed domain. The @du.edu restriction is enforced here (not only in
    // client JS) because the Firebase web API key is public and anyone can
    // obtain a session for an arbitrary email via the Auth REST API.
    // Email-link sign-in produces verified emails, so this holds for all
    // legitimate members. NOTE: the domain is hardcoded to match
    // VITE_ALLOWED_EMAIL_DOMAIN (default "du.edu"); update both if you fork.
    function isMember() {
      return signedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('.*@du[.]edu$');
    }
    function isSelf(uid) {
      return isMember() && request.auth.uid == uid;
    }
    function isAdmin(cohortId) {
      return isMember()
        && get(/databases/$(database)/documents/cohorts/$(cohortId)/admins/$(request.auth.uid)).data.enabled == true;
    }

    match /cohorts/{cohortId} {
      // Admin allowlist docs
      match /admins/{uid} {
        allow read: if isSelf(uid) || isAdmin(cohortId);
        allow write: if false;
      }

      // Member profile docs
      match /members/{uid} {
        allow read: if isSelf(uid) || isAdmin(cohortId);
        allow create: if isSelf(uid)
          && request.resource.data.uid == request.auth.uid;
        allow update: if isSelf(uid)
          && request.resource.data.uid == resource.data.uid;
        // Admin can update teamId field on any member (for team assignment)
        allow update: if isAdmin(cohortId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['teamId']);

        // Per-user saved Explore favorites
        match /favorites/{exploreId} {
          allow read, create, delete: if isSelf(uid);
          allow update: if false;
        }

        // Per-user private file metadata (My Files feature) — March 10
        // Only the owning user can read, create, or delete — admins have no access.
        match /files/{fileId} {
          allow read, create, delete: if isSelf(uid);
          allow update: if false;
        }
      }

      // Announcements (admins manage; all members can read)
      match /announcements/{id} {
        allow read: if isMember();
        allow create, update, delete: if isAdmin(cohortId);
      }

      // Explore items (admins manage; all members can read)
      match /explore/{id} {
        allow read: if isMember();
        allow create: if isAdmin(cohortId);
        allow update, delete: if isAdmin(cohortId);
      }

      // Events (members can read/create; creator or admins can mutate)
      match /events/{eventId} {
        allow read: if isMember();
        allow create: if isMember()
          && request.resource.data.createdByUid == request.auth.uid;
        allow update, delete: if isAdmin(cohortId)
          || (isMember() && resource.data.createdByUid == request.auth.uid);

        match /rsvps/{uid} {
          allow read: if isMember();
          allow create, update: if isSelf(uid);
          allow delete: if isSelf(uid) || isAdmin(cohortId);
        }

        // Event discussion thread — read by any signed-in user;
        // post only if the user has a going/interested RSVP for this event;
        // admin can delete; update never allowed.
        match /messages/{messageId} {
          allow read: if isMember();
          allow create: if isMember()
            && request.resource.data.createdByUid == request.auth.uid
            && request.resource.data.text.size() >= 1
            && request.resource.data.text.size() <= 1000
            && get(/databases/$(database)/documents/cohorts/$(cohortId)/events/$(eventId)/rsvps/$(request.auth.uid)).data.status in ["going", "interested"];
          allow delete: if isAdmin(cohortId);
          allow update: if false;
        }
      }

      // Group chat
      match /messages/{messageId} {
        allow read: if isMember();
        allow create: if isMember()
          && request.resource.data.createdByUid == request.auth.uid
          && request.resource.data.text.size() >= 1
          && request.resource.data.text.size() <= 1000;
        allow delete: if isAdmin(cohortId);
        allow update: if false;
      }

      // Photos (any signed-in user can read; uploader can create; admin can delete)
      // Any signed-in user can update the likes array only; uploader can update their own photo fields.
      match /photos/{photoId} {
        allow read: if isMember();
        // storagePath must live under this uploader's own folder so it can
        // never reference another user's object (see deletePhoto function).
        allow create: if isMember()
          && request.resource.data.uploaderUid == request.auth.uid
          && request.resource.data.storagePath is string
          && request.resource.data.storagePath.matches('photos/' + cohortId + '/' + request.auth.uid + '/.*');
        allow update: if isMember()
          && resource.data.uploaderUid == request.auth.uid;
        allow update: if isMember()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']);
        allow delete: if isAdmin(cohortId);
      }

      // Import logs (admin only)
      match /importLogs/{logId} {
        allow read, write: if isAdmin(cohortId);
      }

      // Media — videos and articles (admin-managed)
      match /media/{mediaId} {
        allow read: if isMember();
        allow create, update, delete: if isAdmin(cohortId);
      }

      // Links — shared trip-planning links (any member creates; creator or admin deletes)
      match /links/{linkId} {
        allow read: if isMember();
        allow create: if isMember()
          && request.resource.data.createdByUid == request.auth.uid
          && request.resource.data.url is string
          && request.resource.data.url.size() <= 500
          && request.resource.data.description is string
          && request.resource.data.description.size() <= 200;
        allow update, delete: if isAdmin(cohortId)
          || (isMember() && resource.data.createdByUid == request.auth.uid);
      }

      // Teams — private small-group hubs
      // Team doc + members subcollection: admin read/write only
      // Messages + meetings: readable/writable only by assigned team members (or admin for meetings/delete)
      match /teams/{teamId} {
        allow read, write: if isAdmin(cohortId);

        match /members/{uid} {
          allow read, write: if isAdmin(cohortId);
        }

        // Helper: is the requesting user an assigned member of this team?
        // Checked by looking up their uid in the members subcollection.
        match /messages/{messageId} {
          allow read: if isAdmin(cohortId)
            || exists(/databases/$(database)/documents/cohorts/$(cohortId)/teams/$(teamId)/members/$(request.auth.uid));
          allow create: if isMember()
            && exists(/databases/$(database)/documents/cohorts/$(cohortId)/teams/$(teamId)/members/$(request.auth.uid))
            && request.resource.data.createdByUid == request.auth.uid
            && request.resource.data.text.size() >= 1
            && request.resource.data.text.size() <= 1000;
          allow delete: if isAdmin(cohortId);
          allow update: if false;
        }

        match /meetings/{meetingId} {
          allow read: if isAdmin(cohortId)
            || exists(/databases/$(database)/documents/cohorts/$(cohortId)/teams/$(teamId)/members/$(request.auth.uid));
          allow create, update, delete: if isAdmin(cohortId);
        }
      }
    }
  }
}
